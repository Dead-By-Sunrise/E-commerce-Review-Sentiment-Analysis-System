# 创建 .gitignore 文件
cat > .gitignore << 'EOF'

# 忽略 BERT 模型文件夹（整个文件夹）
BERT_jd_sentiment_model/
analysis_outputs_full/
analysis_outputs/
goods_cleaned/

# 忽略模型文件
*.bin
*.msgpack
*.h5
*.pth
*.ckpt
*.onnx

# 忽略数据集
data/
dataset/
*.jpg
*.png
*.mp4

# 忽略 Python 缓存
__pycache__/
*.pyc
*.pyo

# 忽略虚拟环境
venv/
env/
ENV/

# 忽略 IDE 配置
.vscode/
.idea/

# 忽略系统文件
.DS_Store
Thumbs.db
EOF
